# =============================================================================
# FLOWBUILDER ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# cp env.example .env.local

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database connection string (Prisma)
# PRISMA_DB_URL_NON_POOLING not needed for SQLite

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# NextAuth.js secret for JWT encryption
AUTH_SECRET="your-auth-secret-here-minimum-32-characters"
NEXTAUTH_SECRET="your-nextauth-secret-here-minimum-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# Custom encryption secret for data encryption
ENCRYPTION_SECRET="your-encryption-secret-here-minimum-32-characters"

# =============================================================================
# GITHUB INTEGRATION
# =============================================================================
# GitHub OAuth credentials
GITHUB_ID="your-github-oauth-client-id"
GITHUB_SECRET="your-github-oauth-client-secret"

# GitHub API token for webhook management
GITHUB_TOKEN="ghp_your-github-personal-access-token"

# =============================================================================
# AWS INTEGRATION
# =============================================================================
# AWS credentials and configuration
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIAyour-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_ACCOUNT_ID="123456789012"

# =============================================================================
# VERCEL INTEGRATION
# =============================================================================
# Vercel API credentials and project configuration
VERCEL_AUTH_BEARER_TOKEN="your-vercel-auth-bearer-token"
VERCEL_PROJECT_ID="prj_your-vercel-project-id"
VERCEL_TEAM_ID="team_your-vercel-team-id"
VERCEL_DOMAIN="your-vercel-domain.vercel.app"

# =============================================================================
# OPENAI INTEGRATION
# =============================================================================
# OpenAI API key for GPT integration
OPENAI_API_KEY="sk-your-openai-api-key"

# =============================================================================
# CACHE & REDIS
# =============================================================================
# Redis connection string for caching and rate limiting
REDIS_URL="redis://localhost:6379"
CACHE_STORE="redis"

# =============================================================================
# DOMAIN & DEPLOYMENT
# =============================================================================
# Root domain configuration
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
NEXT_PUBLIC_VERCEL_DEPLOYMENT_SUFFIX=""

# Valid subdomains for the application
VALID_SUBDOMAINS="demo,test,staging"

# =============================================================================
# THIRD PARTY INTEGRATIONS
# =============================================================================
# Example third-party API backend
THIRD_PARTY_API_EXAMPLE_BACKEND="https://api.example.com"

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
# Service configuration for integration factory
SERVICE_NAME="flowbuilder"
SERVICE_VERSION="1.0.0"
DEBUG="false"
LOG_LEVEL="info"
TIMEOUT_MS="30000"
MAX_RETRIES="3"
RETRY_BACKOFF="exponential"
CACHE_ENABLED="true"
CACHE_TTL="300"
RATE_LIMIT_ENABLED="true"
RATE_LIMIT="100"
RATE_LIMIT_WINDOW="60000"
TELEMETRY_ENABLED="false"

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Node environment
NODE_ENV="development"
# Updated with Neon PostgreSQL connection strings
PRISMA_DB_URL="postgresql://neondb_owner:npg_kVs3pJcP8iuz@ep-wispy-heart-adc39tbz-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require"
PRISMA_DIRECT_URL="postgresql://neondb_owner:npg_kVs3pJcP8iuz@ep-wispy-heart-adc39tbz.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require"
