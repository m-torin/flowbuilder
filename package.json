{
  "name": "flowbuilder",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "pnpm dev:flows",
    "dev:flows": "pnpm run --filter @flowbuilder/flows dev",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev:turbo": "turbo run dev",
    "lint": "turbo lint --only",
    "lint:prettier": "pnpm --filter @flowbuilder/prettier-config format",
    "repo:ci": "turbo repo:ci --concurrency=8",
    "repo:clean": "./scripts/clean-everything.sh",
    "start": "turbo run start",
    "test": "turbo run test",
    "typecheck": "turbo typecheck --only"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@flowbuilder/prettier-config": "workspace:*",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
